<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:padding="24dp">

    <!-- Celebration header -->
    <TextView
        android:id="@+id/tvCelebrate"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/great_job"
        android:textSize="30sp"
        android:textStyle="bold"
        android:textColor="@color/textPrimary"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:paddingTop="32dp" />

    <!-- Avatar celebrating -->
    <TextView
        android:id="@+id/tvAvatarResult"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🎉"
        android:textSize="100sp"
        android:gravity="center"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvCelebrate"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Animated star reward -->
    <TextView
        android:id="@+id/tvStarReward"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⭐"
        android:textSize="80sp"
        android:gravity="center"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvAvatarResult"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- "You earned a star!" -->
    <TextView
        android:id="@+id/tvEarnedStar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/earned_star"
        android:textSize="20sp"
        android:textColor="@color/accent"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvStarReward"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Total stars -->
    <TextView
        android:id="@+id/tvTotalStars"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="18sp"
        android:textColor="@color/textSecondary"
        android:gravity="center"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvEarnedStar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Buttons -->
    <Button
        android:id="@+id/btnPlayAgain"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_marginTop="32dp"
        android:layout_marginEnd="8dp"
        android:text="@string/play_again"
        android:textSize="18sp"
        android:backgroundTint="@color/accent"
        app:layout_constraintTop_toBottomOf="@id/tvTotalStars"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnHome" />

    <Button
        android:id="@+id/btnHome"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_marginTop="32dp"
        android:layout_marginStart="8dp"
        android:text="@string/home"
        android:textSize="18sp"
        android:backgroundTint="@color/textSecondary"
        app:layout_constraintTop_toBottomOf="@id/tvTotalStars"
        app:layout_constraintStart_toEndOf="@id/btnPlayAgain"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
